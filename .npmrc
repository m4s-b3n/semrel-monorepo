# Only fail CI on critical CVEs.
# The 5 high-severity advisories (GHSA-7r86-cg39-jmmj, GHSA-23c5-xmqv-rm74,
# GHSA-qffp-2rhf-9h96) are in tar and minimatch bundled inside npm@11.11.0
# (a transitive dep of @semantic-release/npm). npm overrides cannot reach
# bundled dependencies, and the advisory database is circular (neither
# semantic-release@24 nor @25 is clean). No fix is available upstream.
audit-level=critical
